{
  "name": "@nmtjs/workflows",
  "description": "Workflow design primitives for Neemata.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "module-sync": "./dist/index.js"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./dist/runtime/index.js",
      "module-sync": "./dist/runtime/index.js"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./dist/testing/index.js",
      "module-sync": "./dist/testing/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "module-sync": "./dist/index.js"
      },
      "./runtime": {
        "types": "./dist/runtime/index.d.ts",
        "import": "./dist/runtime/index.js",
        "module-sync": "./dist/runtime/index.js"
      },
      "./testing": {
        "types": "./dist/testing/index.d.ts",
        "import": "./dist/testing/index.js",
        "module-sync": "./dist/testing/index.js"
      }
    }
  },
  "scripts": {
    "clean-build": "rm -rf ./dist"
  },
  "dependencies": {
    "@nmtjs/core": "workspace:*",
    "@nmtjs/type": "workspace:*"
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ]
}
