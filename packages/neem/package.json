{
  "name": "@nmtjs/neem",
  "description": "Neem host core for running compiled application and plugin artifacts.",
  "type": "module",
  "scripts": {
    "clean-build": "rm -rf ./dist"
  },
  "bin": {
    "neem": "./bin/neem.js"
  },
  "exports": {
    ".": {
      "types": "./src/public/index.ts",
      "import": "./dist/public/index.js",
      "module-sync": "./dist/public/index.js"
    },
    "./cli": {
      "types": "./src/cli.ts",
      "import": "./dist/cli.js",
      "module-sync": "./dist/cli.js"
    },
    "./internal": {
      "types": "./src/internal/index.ts",
      "import": "./dist/internal/index.js",
      "module-sync": "./dist/internal/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/public/index.d.ts",
        "import": "./dist/public/index.js",
        "module-sync": "./dist/public/index.js"
      },
      "./cli": {
        "types": "./dist/cli.d.ts",
        "import": "./dist/cli.js",
        "module-sync": "./dist/cli.js"
      },
      "./internal": {
        "types": "./dist/internal/index.d.ts",
        "import": "./dist/internal/index.js",
        "module-sync": "./dist/internal/index.js"
      }
    }
  },
  "dependencies": {
    "@nmtjs/common": "workspace:*",
    "@nmtjs/core": "workspace:*",
    "citty": "0.2.2",
    "consola": "3.4.2",
    "hookable": "6.1.1",
    "oxc-resolver": "11.19.1",
    "perfect-debounce": "2.1.0",
    "rolldown": "1.0.2"
  },
  "peerDependencies": {
    "@nmtjs/proxy": "catalog:"
  },
  "peerDependenciesMeta": {
    "@nmtjs/proxy": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nmtjs/proxy": "catalog:",
    "@types/node": "^24"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ]
}
