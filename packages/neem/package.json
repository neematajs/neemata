{
  "name": "@nmtjs/neem",
  "description": "Neemata Application Server",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neematajs/neemata.git",
    "directory": "packages/neem"
  },
  "scripts": {
    "clean-build": "rm -rf ./dist"
  },
  "bin": {
    "neem": "./bin/neem.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "module-sync": "./dist/index.js"
    },
    "./cli": {
      "types": "./src/cli.ts",
      "import": "./dist/cli.js",
      "module-sync": "./dist/cli.js"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./dist/runtime/index.js",
      "module-sync": "./dist/runtime/index.js"
    },
    "./vite/*": {
      "types": "./src/vite/*.ts",
      "import": "./dist/vite/*.js",
      "module-sync": "./dist/vite/*.js"
    }
  },
  "dependencies": {
    "@nmtjs/common": "workspace:*",
    "@nmtjs/core": "workspace:*",
    "citty": "0.2.1",
    "dotenv": "17.3.1",
    "hookable": "6.0.1",
    "oxc-resolver": "11.19.1",
    "prom-client": "git@github.com:siimon/prom-client.git#d4d2dcb366384833951e0116caca707b5f62aa5e"
  },
  "devDependencies": {
    "@nmtjs/proxy": "catalog:",
    "pino": "10.3.0",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@nmtjs/proxy": "catalog:",
    "pino": "10.3.0",
    "vite": "catalog:"
  },
  "peerDependenciesMeta": {
    "@nmtjs/proxy": {
      "optional": true
    }
  },
  "files": [
    "bin",
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ]
}
