{
  "name": "nmtjs",
  "description": "Neemata framework umbrella package.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "module-sync": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "module-sync": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@nmtjs/application": "workspace:*",
    "@nmtjs/contract": "workspace:*",
    "@nmtjs/core": "workspace:*",
    "@nmtjs/gateway": "workspace:*",
    "@nmtjs/metrics": "workspace:*",
    "@nmtjs/protocol": "workspace:*",
    "@nmtjs/pubsub": "workspace:*",
    "@nmtjs/type": "workspace:*"
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ]
}
