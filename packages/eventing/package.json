{
  "name": "@nmtjs/eventing",
  "description": "Neemata typed durable event streams and runtime consumers.",
  "type": "module",
  "scripts": {
    "clean-build": "rm -rf ./dist",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.ts tests/integration"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "module-sync": "./dist/index.js"
    },
    "./kafka": {
      "types": "./src/kafka.ts",
      "import": "./dist/kafka.js",
      "module-sync": "./dist/kafka.js"
    },
    "./redis-streams": {
      "types": "./src/redis-streams.ts",
      "import": "./dist/redis-streams.js",
      "module-sync": "./dist/redis-streams.js"
    },
    "./neem": {
      "types": "./src/neem/index.ts",
      "import": "./dist/neem/index.js",
      "module-sync": "./dist/neem/index.js"
    },
    "./neem/worker-entry": {
      "types": "./src/neem/worker-entry.ts",
      "import": "./dist/neem/worker-entry.js",
      "module-sync": "./dist/neem/worker-entry.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "module-sync": "./dist/index.js"
      },
      "./kafka": {
        "types": "./dist/kafka.d.ts",
        "import": "./dist/kafka.js",
        "module-sync": "./dist/kafka.js"
      },
      "./redis-streams": {
        "types": "./dist/redis-streams.d.ts",
        "import": "./dist/redis-streams.js",
        "module-sync": "./dist/redis-streams.js"
      },
      "./neem": {
        "types": "./dist/neem/index.d.ts",
        "import": "./dist/neem/index.js",
        "module-sync": "./dist/neem/index.js"
      },
      "./neem/worker-entry": {
        "types": "./dist/neem/worker-entry.d.ts",
        "import": "./dist/neem/worker-entry.js",
        "module-sync": "./dist/neem/worker-entry.js"
      }
    }
  },
  "dependencies": {
    "@nmtjs/application": "workspace:*",
    "@nmtjs/common": "workspace:*",
    "@nmtjs/contract": "workspace:*",
    "@nmtjs/core": "workspace:*",
    "@nmtjs/neem": "workspace:*",
    "@nmtjs/type": "workspace:*"
  },
  "peerDependencies": {
    "@platformatic/kafka": "^2.1.0",
    "ioredis": "^5.10.1",
    "iovalkey": "^0.3.3"
  },
  "peerDependenciesMeta": {
    "@platformatic/kafka": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "iovalkey": {
      "optional": true
    }
  },
  "devDependencies": {
    "@platformatic/kafka": "^2.1.0",
    "ioredis": "^5.10.1",
    "iovalkey": "^0.3.3"
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ]
}
