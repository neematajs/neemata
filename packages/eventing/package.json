{
  "name": "@nmtjs/eventing",
  "description": "Neemata typed durable event streams and runtime consumers.",
  "type": "module",
  "scripts": {
    "clean-build": "rm -rf ./dist",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.ts tests/integration"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "module-sync": "./dist/index.js"
    },
    "./kafka": {
      "types": "./src/kafka.ts",
      "import": "./dist/kafka.js",
      "module-sync": "./dist/kafka.js"
    },
    "./redis": {
      "types": "./src/redis.ts",
      "import": "./dist/redis.js",
      "module-sync": "./dist/redis.js"
    },
    "./neem/runtime": {
      "types": "./src/neem/runtime.ts",
      "import": "./dist/neem/runtime.js",
      "module-sync": "./dist/neem/runtime.js"
    },
    "./neem/worker": {
      "types": "./src/neem/worker.ts",
      "import": "./dist/neem/worker.js",
      "module-sync": "./dist/neem/worker.js"
    },
    "./neem/planner": {
      "types": "./src/neem/planner.ts",
      "import": "./dist/neem/planner.js",
      "module-sync": "./dist/neem/planner.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "module-sync": "./dist/index.js"
      },
      "./kafka": {
        "types": "./dist/kafka.d.ts",
        "import": "./dist/kafka.js",
        "module-sync": "./dist/kafka.js"
      },
      "./redis": {
        "types": "./dist/redis.d.ts",
        "import": "./dist/redis.js",
        "module-sync": "./dist/redis.js"
      },
      "./neem/runtime": {
        "types": "./dist/neem/runtime.d.ts",
        "import": "./dist/neem/runtime.js",
        "module-sync": "./dist/neem/runtime.js"
      },
      "./neem/worker": {
        "types": "./dist/neem/worker.d.ts",
        "import": "./dist/neem/worker.js",
        "module-sync": "./dist/neem/worker.js"
      },
      "./neem/planner": {
        "types": "./dist/neem/planner.d.ts",
        "import": "./dist/neem/planner.js",
        "module-sync": "./dist/neem/planner.js"
      }
    }
  },
  "dependencies": {
    "@nmtjs/application": "workspace:*",
    "@nmtjs/common": "workspace:*",
    "@nmtjs/contract": "workspace:*",
    "@nmtjs/core": "workspace:*",
    "@nmtjs/neem": "workspace:*",
    "@nmtjs/type": "workspace:*"
  },
  "peerDependencies": {
    "@platformatic/kafka": "^2.1.0",
    "ioredis": "^5.10.1",
    "iovalkey": "^0.3.3"
  },
  "peerDependenciesMeta": {
    "@platformatic/kafka": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "iovalkey": {
      "optional": true
    }
  },
  "devDependencies": {
    "@platformatic/kafka": "^2.3.1",
    "ioredis": "^5.11.1",
    "iovalkey": "^0.3.3"
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ]
}
