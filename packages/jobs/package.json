{
  "name": "@nmtjs/jobs",
  "description": "Neem jobs runtime contracts and BullMQ integration.",
  "type": "module",
  "scripts": {
    "clean-build": "rm -rf ./dist"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "module-sync": "./dist/index.js"
    },
    "./neem": {
      "types": "./src/neem/index.ts",
      "import": "./dist/neem/index.js",
      "module-sync": "./dist/neem/index.js"
    },
    "./neem/host": {
      "types": "./src/neem/host.ts",
      "import": "./dist/neem/host.js",
      "module-sync": "./dist/neem/host.js"
    },
    "./neem/worker-entry": {
      "types": "./src/neem/worker-entry.ts",
      "import": "./dist/neem/worker-entry.js",
      "module-sync": "./dist/neem/worker-entry.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "module-sync": "./dist/index.js"
      },
      "./neem": {
        "types": "./dist/neem/index.d.ts",
        "import": "./dist/neem/index.js",
        "module-sync": "./dist/neem/index.js"
      },
      "./neem/host": {
        "types": "./dist/neem/host.d.ts",
        "import": "./dist/neem/host.js",
        "module-sync": "./dist/neem/host.js"
      },
      "./neem/worker-entry": {
        "types": "./dist/neem/worker-entry.d.ts",
        "import": "./dist/neem/worker-entry.js",
        "module-sync": "./dist/neem/worker-entry.js"
      }
    }
  },
  "dependencies": {
    "@nmtjs/common": "workspace:*",
    "@nmtjs/application": "workspace:*",
    "@nmtjs/contract": "workspace:*",
    "@nmtjs/core": "workspace:*",
    "@nmtjs/type": "workspace:*",
    "@nmtjs/neem": "workspace:*",
    "bullmq": "5.77.0"
  },
  "peerDependencies": {
    "ioredis": "^5.10.1",
    "iovalkey": "^0.3.3"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "iovalkey": {
      "optional": true
    }
  },
  "devDependencies": {
    "ioredis": "^5.10.1",
    "iovalkey": "^0.3.3"
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ]
}
