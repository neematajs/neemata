{
  "name": "@nmtjs/pubsub",
  "description": "Neemata ephemeral publish/subscribe injectables and adapters.",
  "type": "module",
  "scripts": {
    "clean-build": "rm -rf ./dist",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.ts tests/integration"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "module-sync": "./dist/index.js"
    },
    "./redis": {
      "types": "./src/redis.ts",
      "import": "./dist/redis.js",
      "module-sync": "./dist/redis.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "module-sync": "./dist/index.js"
      },
      "./redis": {
        "types": "./dist/redis.d.ts",
        "import": "./dist/redis.js",
        "module-sync": "./dist/redis.js"
      }
    }
  },
  "dependencies": {
    "@nmtjs/common": "workspace:*",
    "@nmtjs/contract": "workspace:*",
    "@nmtjs/core": "workspace:*"
  },
  "devDependencies": {
    "@nmtjs/application": "workspace:*",
    "@nmtjs/type": "workspace:*",
    "ioredis": "^5.11.1",
    "iovalkey": "^0.3.3"
  },
  "peerDependencies": {
    "ioredis": "^5.10.1",
    "iovalkey": "^0.3.3"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "iovalkey": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ]
}
