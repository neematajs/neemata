{
  "name": "@nmtjs/application",
  "description": "Neemata application model, API pipeline, and application lifecycle primitives.",
  "type": "module",
  "scripts": {
    "clean-build": "rm -rf ./dist"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "module-sync": "./dist/index.js"
    },
    "./neem": {
      "types": "./src/neem.ts",
      "import": "./dist/neem.js",
      "module-sync": "./dist/neem.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "module-sync": "./dist/index.js"
      },
      "./neem": {
        "types": "./dist/neem.d.ts",
        "import": "./dist/neem.js",
        "module-sync": "./dist/neem.js"
      }
    }
  },
  "dependencies": {
    "@nmtjs/common": "workspace:*",
    "@nmtjs/contract": "workspace:*",
    "@nmtjs/core": "workspace:*",
    "@nmtjs/gateway": "workspace:*",
    "@nmtjs/protocol": "workspace:*",
    "@nmtjs/type": "workspace:*",
    "@nmtjs/neem": "workspace:*"
  },
  "devDependencies": {
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@nmtjs/common": "workspace:*",
    "@nmtjs/contract": "workspace:*",
    "@nmtjs/core": "workspace:*",
    "@nmtjs/gateway": "workspace:*",
    "@nmtjs/protocol": "workspace:*",
    "@nmtjs/type": "workspace:*",
    "@nmtjs/neem": "workspace:*",
    "zod": "catalog:"
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ]
}
