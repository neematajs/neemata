{
  "name": "neemata",
  "private": true,
  "type": "module",
  "scripts": {
    "clean-build": "pnpm run --parallel -r clean-build",
    "build": "pnpm run clean-build && pnpm tsgo -b tsconfig.build.json",
    "dev": "pnpm run clean-build && pnpm tsgo -b tsconfig.build.json --watch",
    "clean": "rm -rf dist node_modules && pnpm -r exec rm -rf dist node_modules",
    "test": "pnpm build && vitest --run",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:jobs": "pnpm --filter tests-e2e run test:jobs",
    "test:e2e:jobs:docker": "sh -c 'docker compose -f tests/e2e/docker-compose.jobs-e2e.yml run --rm --build test-jobs; code=$?; docker compose -f tests/e2e/docker-compose.jobs-e2e.yml down -v --remove-orphans; exit $code'",
    "test:unit": "vitest run packages/*",
    "test:browser:client": "vitest run -c packages/client/vitest.browser.config.ts",
    "test:dev": "vitest dev --ui --coverage",
    "check:type": "pnpm tsgo -b tsconfig.json --noEmit",
    "check:lint": "biome lint --diagnostic-level=error .",
    "check:fmt": "biome format --diagnostic-level=error .",
    "check": "pnpm run check:fmt && pnpm run check:lint && pnpm run check:type",
    "fmt": "biome check --diagnostic-level=error --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24",
    "@typescript/native-preview": "7.0.0-dev.20260418.1",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "vitest": "4.1.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
