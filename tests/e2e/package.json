    "@nmtjs/scheduler": "workspace:*",
    "@nmtjs/type": "workspace:*",
    "@platformatic/kafka": "^2.1.0",
    "bullmq": "^5.66.0",
    "ioredis": "^5.10.1",
    "vitest": "4.1.7"
  },
  "devDependencies": {
    "@types/node": "^24"
  }
}
